@page "/register"
@layout LoginLayout
@using System.ComponentModel.DataAnnotations
@using Entcuentro.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject ITokenManager TokenManager

<PageTitle>Crear cuenta — E.N.T.C.U.E.N.T.R.O.</PageTitle>

<div class="login-card card shadow-lg">
    <div class="card-body p-5">

        <div class="text-center mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="56" height="56" viewBox="0 0 72 72" class="login-logo" aria-hidden="true">
                <circle cx="36" cy="36" r="34" fill="#198754" />
                <circle cx="36" cy="36" r="28" fill="#28a745" opacity="0.4" />
                <text x="36" y="50" text-anchor="middle" font-family="Arial,sans-serif" font-size="32" font-weight="bold" fill="white">ENT</text>
            </svg>
            <h1 class="h5 mt-3 mb-0 fw-bold" style="color:#2c1a0e;">Únete a la partida</h1>
            <p class="text-muted" style="font-size:0.78rem;">E.N.T.C.U.E.N.T.R.O.</p>
        </div>

        <EditForm Model="model" OnValidSubmit="HandleRegisterAsync">
            <DataAnnotationsValidator />

            @if (errorMessage is not null)
            {
                <div class="alert alert-danger d-flex align-items-center" role="alert">
                    <span class="flex-grow-1">@errorMessage</span>
                    <button type="button" class="btn-close ms-2" aria-label="Cerrar"
                            @onclick="() => errorMessage = null"></button>
                </div>
            }

            <div class="mb-3">
                <label for="username" class="form-label fw-semibold">Nombre de usuario</label>
                <InputText id="username" @bind-Value="model.UserName" class="form-control"
                           placeholder="como quieres que te llamen" autocomplete="username" />
                <ValidationMessage For="() => model.UserName" class="text-danger small mt-1" />
            </div>

            <div class="mb-3">
                <label for="email" class="form-label fw-semibold">Correo electrónico</label>
                <InputText id="email" @bind-Value="model.Email" class="form-control"
                           type="email" placeholder="para recuperar tu cuenta" autocomplete="email" />
                <ValidationMessage For="() => model.Email" class="text-danger small mt-1" />
            </div>

            <div class="mb-3">
                <label for="password" class="form-label fw-semibold">Contraseña</label>
                <div class="input-group">
                    <InputText id="password" @bind-Value="model.Password" class="form-control"
                               type="@(showPassword ? "text" : "password")"
                               autocomplete="new-password" />
                    <button type="button" class="btn btn-outline-secondary px-3"
                            @onclick="TogglePassword" tabindex="-1">
                        @if (showPassword)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                                <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                                <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z" />
                            </svg>
                        }
                        else
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                                <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                            </svg>
                        }
                    </button>
                </div>
                <ValidationMessage For="() => model.Password" class="text-danger small mt-1" />
            </div>

            <div class="mb-3">
                <label for="confirm" class="form-label fw-semibold">Confirmar contraseña</label>
                <InputText id="confirm" @bind-Value="model.ConfirmPassword" class="form-control"
                           type="@(showPassword ? "text" : "password")"
                           autocomplete="new-password" />
                <ValidationMessage For="() => model.ConfirmPassword" class="text-danger small mt-1" />
            </div>

            <div class="mb-4">
                <label for="localidad" class="form-label fw-semibold">
                    Localidad <span class="text-muted fw-normal" style="font-size:0.8rem;">(opcional)</span>
                </label>
                <InputText id="localidad" @bind-Value="model.Localidad" class="form-control"
                           placeholder="tu ciudad o pueblo, para encontrar tiendas cerca" />
                <div class="form-text" style="font-size:0.76rem;color:#6b5c3e;">
                    Sin GPS, sin rastreo. Solo para mostrarte tiendas de tu zona.
                </div>
            </div>

            <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                @if (isLoading)
                {
                    <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                }
                Unirme a la partida
            </button>
        </EditForm>

        <div class="text-center mt-3" style="font-size:0.85rem;">
            <span style="color:#6b5c3e;">¿Ya tienes cuenta?</span>
            <a href="/login" class="ms-1 fw-semibold" style="color:#2e5039;">Iniciar sesión</a>
        </div>

    </div>
</div>

@code {
    private readonly RegisterModel model = new();
    private string? errorMessage;
    private bool isLoading;
    private bool showPassword;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
            Nav.NavigateTo("/", replace: true);
    }

    private async Task HandleRegisterAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var request = new RegisterRequest(model.Email, model.Password, model.UserName,
                string.IsNullOrWhiteSpace(model.Localidad) ? null : model.Localidad.Trim());

            var response = await Http.PostAsJsonAsync("api/auth/register", request);

            if (!response.IsSuccessStatusCode)
            {
                var err = await response.Content.ReadFromJsonAsync<ErrorResponse>();
                errorMessage = err?.Message ?? "No se pudo crear la cuenta.";
                return;
            }

            var auth = await response.Content.ReadFromJsonAsync<AuthResponse>();
            if (auth is null)
            {
                errorMessage = "Error al procesar la respuesta del servidor.";
                return;
            }

            await TokenManager.NotifyAuthenticatedAsync(auth.AccessToken);
            Nav.NavigateTo("/", replace: true);
        }
        catch
        {
            errorMessage = "No se puede conectar con el servidor. Comprueba tu conexión.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TogglePassword() => showPassword = !showPassword;

    private sealed class RegisterModel
    {
        [Required(ErrorMessage = "El nombre de usuario es obligatorio.")]
        [MinLength(3, ErrorMessage = "Mínimo 3 caracteres.")]
        [MaxLength(50, ErrorMessage = "Máximo 50 caracteres.")]
        public string UserName { get; set; } = string.Empty;

        [Required(ErrorMessage = "El correo es obligatorio.")]
        [EmailAddress(ErrorMessage = "Introduce un correo válido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        [MinLength(6, ErrorMessage = "Mínimo 6 caracteres.")]
        public string Password { get; set; } = string.Empty;

        [Required(ErrorMessage = "Confirma la contraseña.")]
        [Compare(nameof(Password), ErrorMessage = "Las contraseñas no coinciden.")]
        public string ConfirmPassword { get; set; } = string.Empty;

        [MaxLength(100)]
        public string? Localidad { get; set; }
    }

    private sealed record ErrorResponse(string Message);
}
