@page "/login"
@layout LoginLayout
@using System.ComponentModel.DataAnnotations
@using Entcuentro.Shared.DTOs
@inject HttpClient Http
@inject NavigationManager Nav
@inject AuthenticationStateProvider AuthStateProvider
@inject ITokenManager TokenManager

<PageTitle>Iniciar sesión — E.N.T.C.U.E.N.T.R.O.</PageTitle>

<div class="login-card card shadow-lg border-0">
        <div class="card-body p-5">

            <div class="text-center mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="72" height="72" viewBox="0 0 72 72" class="login-logo" aria-hidden="true">
                    <circle cx="36" cy="36" r="34" fill="#198754" />
                    <circle cx="36" cy="36" r="28" fill="#28a745" opacity="0.4" />
                    <text x="36" y="50" text-anchor="middle" font-family="Arial,sans-serif" font-size="32" font-weight="bold" fill="white">ENT</text>
                </svg>
                <h1 class="h4 mt-3 mb-0 fw-bold text-success" style="letter-spacing: 2px;">E.N.T.C.U.E.N.T.R.O.</h1>
                <p class="text-muted" style="font-size: 0.7rem;">Enganchados Nerds Tirando Cartas Unidos En Nuestras Tiendas Ruinosas y Olorosas</p>
            </div>

            <EditForm Model="model" OnValidSubmit="HandleLoginAsync">
                <DataAnnotationsValidator />

                @if (errorMessage is not null)
                {
                    <div class="alert alert-danger d-flex align-items-center" role="alert">
                        <span class="flex-grow-1">@errorMessage</span>
                        <button type="button" class="btn-close ms-2" aria-label="Cerrar" @onclick="() => errorMessage = null"></button>
                    </div>
                }

                <div class="mb-3">
                    <label for="email" class="form-label fw-semibold">Correo electrónico</label>
                    <InputText id="email" @bind-Value="model.Email" class="form-control form-control-lg"
                               type="email" placeholder="usuario@ejemplo.com" autocomplete="email" />
                    <ValidationMessage For="() => model.Email" class="text-danger small mt-1" />
                </div>

                <div class="mb-3">
                    <label for="password" class="form-label fw-semibold">Contraseña</label>
                    <div class="input-group input-group-lg">
                        <InputText id="password" @bind-Value="model.Password" class="form-control"
                                   type="@(showPassword ? "text" : "password")"
                                   autocomplete="current-password" />
                        <button type="button" class="btn btn-outline-secondary px-3"
                                @onclick="TogglePassword" tabindex="-1"
                                title="@(showPassword ? "Ocultar contraseña" : "Mostrar contraseña")">
                            @if (showPassword)
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M13.359 11.238C15.06 9.72 16 8 16 8s-3-5.5-8-5.5a7 7 0 0 0-2.79.588l.77.771A6 6 0 0 1 8 3.5c2.12 0 3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755q-.247.248-.517.486z" />
                                    <path d="M11.297 9.176a3.5 3.5 0 0 0-4.474-4.474l.823.823a2.5 2.5 0 0 1 2.829 2.829zm-2.943 1.299.822.822a3.5 3.5 0 0 1-4.474-4.474l.823.823a2.5 2.5 0 0 0 2.829 2.829" />
                                    <path d="M3.35 5.47q-.27.24-.518.487A13 13 0 0 0 1.172 8l.195.288c.335.48.83 1.12 1.465 1.755C4.121 11.332 5.881 12.5 8 12.5c.716 0 1.39-.133 2.02-.36l.77.772A7 7 0 0 1 8 13.5C3 13.5 0 8 0 8s.939-1.721 2.641-3.238l.708.709zm10.296 8.884-12-12 .708-.708 12 12z" />
                                </svg>
                            }
                            else
                            {
                                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" fill="currentColor" viewBox="0 0 16 16">
                                    <path d="M16 8s-3-5.5-8-5.5S0 8 0 8s3 5.5 8 5.5S16 8 16 8M1.173 8a13 13 0 0 1 1.66-2.043C4.12 4.668 5.88 3.5 8 3.5s3.879 1.168 5.168 2.457A13 13 0 0 1 14.828 8q-.086.13-.195.288c-.335.48-.83 1.12-1.465 1.755C11.879 11.332 10.119 12.5 8 12.5s-3.879-1.168-5.168-2.457A13 13 0 0 1 1.172 8z" />
                                    <path d="M8 5.5a2.5 2.5 0 1 0 0 5 2.5 2.5 0 0 0 0-5M4.5 8a3.5 3.5 0 1 1 7 0 3.5 3.5 0 0 1-7 0" />
                                </svg>
                            }
                        </button>
                    </div>
                    <ValidationMessage For="() => model.Password" class="text-danger small mt-1" />
                </div>

                <div class="mb-4 form-check">
                    <input type="checkbox" class="form-check-input" id="rememberMe" @bind="rememberMe" />
                    <label class="form-check-label text-muted" for="rememberMe">Recordar usuario</label>
                </div>

                <button type="submit" class="btn btn-primary btn-lg w-100" disabled="@isLoading">
                    @if (isLoading)
                    {
                        <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                    }
                    Iniciar sesión
                </button>
            </EditForm>

        </div>
</div>

<div class="login-card mt-3">
    <div class="text-center">
        <button class="btn btn-link btn-sm text-muted text-decoration-none" type="button"
                @onclick="ToggleAbout">
            @(showAbout ? "Ocultar" : "¿Qué narices es esto?")
        </button>
    </div>

    @if (showAbout)
    {
        <div class="card shadow-sm border-0 mt-2 p-4 text-center" style="max-width: 420px; font-size: 0.88rem;">
            <p>
                <strong>E.N.T.C.U.E.N.T.R.O.</strong> — como los Ents del Señor de los Anillos,
                pero en lugar de caminar muy despacio hacia Isengard, aquí quedamos para jugar a cartas.
            </p>
            <p>
                ¿Te has plantado en tu tienda favorita un sábado y no había ni un alma?
                ¿Has mandado un mensaje a cuatro grupos de WhatsApp y nadie ha contestado hasta el lunes?
                Esto es para ti.
            </p>
            <p>
                Dile al mundo que estarás en la Tienda X jugando a Y entre las H1 y las H2.
                Encuentra a otros igual de perdidos. Monta una partida antes de salir de casa.
            </p>
            <p class="text-muted mb-0" style="font-size: 0.78rem;">
                Hecho por jugadores, para jugadores.<br />
                Con amor, frikismo y demasiado tiempo libre.
            </p>
        </div>
    }
</div>

@code {
    private bool showAbout;
    private readonly LoginModel model = new();
    private string? errorMessage;
    private bool isLoading;
    private bool showPassword;
    private bool rememberMe;

    protected override async Task OnInitializedAsync()
    {
        var state = await AuthStateProvider.GetAuthenticationStateAsync();
        if (state.User.Identity?.IsAuthenticated == true)
        {
            Nav.NavigateTo("/", replace: true);
            return;
        }

        var remembered = await TokenManager.GetRememberedEmailAsync();
        if (!string.IsNullOrEmpty(remembered))
        {
            model.Email = remembered;
            rememberMe = true;
        }
    }

    private async Task HandleLoginAsync()
    {
        isLoading = true;
        errorMessage = null;

        try
        {
            var response = await Http.PostAsJsonAsync("api/auth/login", new LoginRequest(model.Email, model.Password));

            if (!response.IsSuccessStatusCode)
            {
                errorMessage = "Correo o contraseña incorrectos.";
                return;
            }

            var auth = await response.Content.ReadFromJsonAsync<AuthResponse>();
            if (auth is null)
            {
                errorMessage = "Error al procesar la respuesta del servidor.";
                return;
            }

            if (rememberMe)
                await TokenManager.SaveRememberedEmailAsync(model.Email);
            else
                await TokenManager.RemoveRememberedEmailAsync();

            await TokenManager.NotifyAuthenticatedAsync(auth.AccessToken);
            Nav.NavigateTo("/", replace: true);
        }
        catch
        {
            errorMessage = "No se puede conectar con el servidor. Comprueba tu conexión.";
        }
        finally
        {
            isLoading = false;
        }
    }

    private void TogglePassword() => showPassword = !showPassword;
    private void ToggleAbout() => showAbout = !showAbout;

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "El correo es obligatorio.")]
        [EmailAddress(ErrorMessage = "Introduce un correo válido.")]
        public string Email { get; set; } = string.Empty;

        [Required(ErrorMessage = "La contraseña es obligatoria.")]
        public string Password { get; set; } = string.Empty;
    }
}
